      <aliases enabled='yes' />
      <column caption='Clean Fat Content' datatype='string' name='[Calculation_1127025860238929920]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LOWER([Item Fat Content]) = &quot;lf&quot; OR LOWER([Item Fat Content]) = &quot;low fat&quot; THEN &quot;Low Fat&quot;&#13;&#10;ELSEIF LOWER([Item Fat Content]) = &quot;reg&quot; OR LOWER([Item Fat Content]) = &quot;regular&quot; THEN &quot;Regular&quot;&#13;&#10;ELSE [Item Fat Content]&#13;&#10;END' />
      </column>
      <column caption='Clean Item Weight' datatype='real' name='[Calculation_1127025860239085569]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Item Weight], {FIXED : AVG([Item Weight])})' />
      </column>
      <column caption='Outlet Age' datatype='integer' name='[Calculation_1127025860239282178]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;, [Outlet Establishment Year], TODAY())' />
      </column>
      <column caption='Clean Outlet Size' datatype='string' name='[Calculation_1127025860239462403]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([Outlet Size]) THEN &quot;Unknown&quot;&#13;&#10;ELSEIF LOWER([Outlet Size]) = &quot;small&quot; THEN &quot;Small&quot;&#13;&#10;ELSEIF LOWER([Outlet Size]) = &quot;medium&quot; THEN &quot;Medium&quot;&#13;&#10;ELSEIF LOWER([Outlet Size]) = &quot;high&quot; THEN &quot;High&quot;&#13;&#10;ELSE [Outlet Size]&#13;&#10;END' />
      </column>
      <column caption='Clean Item Visibility' datatype='real' name='[Calculation_1127025860239667204]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Item Visibility] = 0 THEN {FIXED : AVG([Item Visibility])}&#13;&#10;ELSE [Item Visibility]&#13;&#10;END' />
      </column>
      <column caption='Sales Rank' datatype='integer' name='[Calculation_1127025860245164041]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(SUM([Total Sales]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
